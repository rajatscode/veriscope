    "./layout": {
      "types": "./dist/layout.d.ts",
      "import": "./dist/layout.js",
      "require": "./dist/layout.cjs"
    }
  },
  "files": ["dist"],
  "dependencies": {
    "@veriscope/graph": "*"
  },
  "devDependencies": {
    "jsdom": "^25.0.1",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
