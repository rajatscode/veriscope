{
  "name": "@veriscope/cli",
  "version": "0.0.1",
  "type": "module",
  "bin": {
    "veriscope": "./dist/index.js"
  },
  "main": "dist/api.js",
  "types": "dist/api.d.ts",
  "exports": {
    ".": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js"
    },
    "./cli": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@veriscope/graph": "*"
  },
  "scripts": {
    "build": "tsup src/index.ts src/api.ts --format esm --dts",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
